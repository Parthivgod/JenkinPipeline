pipeline {
    agent any

    tools {
        // Automatically install/use Maven & JDK defined in 'Global Tool Configuration'
        maven 'Maven 3.3.9' 
        jdk 'jdk8'
    }

    stages {
        stage('Pull from Git') {
            steps {
                // Declarative pipelines automatically checkout SCM, 
                // but you can explicitly call it using the git step.
                git branch: 'main', url: 'https://github.com'
            }
        }

        stage('Build') {
            steps {
                echo 'Starting Build...'
                // If using the Pipeline Maven Plugin, use withMaven instead of sh
                withMaven(maven: 'Maven 3.3.9') {
                    // This internal step invokes maven without a manual 'sh'
                    // Alternatively, on Windows use: bat 'mvn clean package'
                    echo 'Building via Maven Plugin...'
                }
            }
        }

        stage('Test') {
            steps {
                echo 'Running Tests...'
                // For Windows agents, use bat instead of sh
                bat 'mvn test' 
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying application...'
                // Use built-in archiveArtifacts to "deploy" to Jenkins itself
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished.'
        }
    }
}
